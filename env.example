# ─────────────────────────────────────────────
# Living API Docs — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file
# ─────────────────────────────────────────────

# Groq LLM (get from console.groq.com — free)
GROQ_API_KEY=your_groq_api_key_here

# GitHub Personal Access Token (needs repo scope)
GITHUB_TOKEN=your_github_pat_here

# SendGrid Email (for doc update notifications)
SENDGRID_API_KEY=your_sendgrid_api_key_here
FROM_EMAIL=your_verified_sender@yourdomain.com

# Your deployed app URL (update after Streamlit Cloud deploy)
APP_URL=http://localhost:8501

# Webhook secret (generate: python -c "import secrets; print(secrets.token_hex(32))")
WEBHOOK_SECRET=your_webhook_secret_here

# Polling interval in seconds (10 for demo, 30 for normal)
POLL_INTERVAL_SECONDS=30
